{
    "name": "@autonoma/job-scenario",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --passWithNoTests",
        "test:scenario": "tsx --env-file=../../../.env src/test-scenario.ts"
    },
    "dependencies": {
        "@autonoma/db": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/scenario": "workspace:*",
        "@autonoma/try": "workspace:*",
        "@sentry/node": "catalog:",
        "@t3-oss/env-core": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "tsup": "^8.5.1",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
