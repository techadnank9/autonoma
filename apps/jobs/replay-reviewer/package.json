{
    "name": "@autonoma/replay-reviewer",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --passWithNoTests",
        "review": "tsx --env-file=../../../.env src/index.ts"
    },
    "dependencies": {
        "@autonoma/ai": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/review": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/types": "workspace:*",
        "@google/genai": "^1.42.0",
        "@sentry/node": "catalog:",
        "@t3-oss/env-core": "catalog:",
        "ai": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "tsup": "^8.5.1",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
