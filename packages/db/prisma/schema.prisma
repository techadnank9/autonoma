generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["tracing"]
}

datasource db {
  provider = "postgresql"
}

generator json {
  provider = "prisma-json-types-generator"
}

// ─── Better Auth Core Models ────────────────────────────────────────

enum UserRole {
  user
  admin

  @@map("user_role")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  role          UserRole @default(user)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions       Session[]
  accounts       Account[]
  members        Member[]
  invitations    Invitation[] @relation("invitations")
  apiKeys        ApiKey[]
  applicationSetups ApplicationSetup[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activeOrganizationId String? @map("active_organization_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verification")
}

// ─── Organization Plugin Models ─────────────────────────────────────

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  logo      String?
  metadata  String?
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  domain    String?            @unique
  status    OrganizationStatus @default(approved)

  members            Member[]
  invitations        Invitation[]
  applications       Application[]
  branchDeployments  BranchDeployment[]
  webDeployments     WebDeployment[]
  mobileDeployments  MobileDeployment[]
  folders            Folder[]
  branches           Branch[]
  testCases          TestCase[]
  testPlans          TestPlan[]
  testGenerations    TestGeneration[]
  stepInputLists     StepInputList[]
  stepInputs         StepInput[]
  stepOutputLists    StepOutputList[]
  stepOutputs        StepOutput[]
  tags               Tag[]
  runs               Run[]
  scenarios          Scenario[]
  scenarioInstances  ScenarioInstance[]
  skills             Skill[]
  skillPlans         SkillPlan[]
  generationReviews  GenerationReview[]
  runReviews         RunReview[]
  issues             Issue[]
  bugs               Bug[]
  githubInstallation GitHubInstallation?
  billingPricing       BillingPricing?
  promoRedemptions     BillingPromoRedemption[]
  billingCustomer     BillingCustomer?
  applicationSetups  ApplicationSetup[]

  @@map("organization")
}

model OnboardingState {
  id                    String    @id @default(cuid())
  applicationId         String    @unique @map("application_id")
  currentStep           Int       @default(0) @map("current_step")
  agentConnectedAt      DateTime? @map("agent_connected_at")
  /// @prisma-json-types-generator/types AgentLogEntry[]
  agentLogs             Json      @default("[]") @map("agent_logs")
  ngrokUrl              String?   @map("ngrok_url")
  ngrokTestsPassed      Boolean   @default(false) @map("ngrok_tests_passed")
  productionUrl         String?   @map("production_url")
  productionTestsPassed Boolean   @default(false) @map("production_tests_passed")
  completedAt           DateTime? @map("completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    @@map("onboarding_state")
}

// ─── Application Setup ──────────────────────────────────────────────

model ApplicationSetup {
    id           String    @id @default(cuid())
    name         String?
    status       String    @default("running")
    currentStep  Int       @default(0) @map("current_step")
    totalSteps   Int       @default(4) @map("total_steps")
    errorMessage String?   @map("error_message")
    completedAt  DateTime? @map("completed_at")

    applicationId  String       @map("application_id")
    application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
    organizationId String       @map("organization_id")
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    userId         String       @map("user_id")
    user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    events ApplicationSetupEvent[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@index([applicationId])
    @@index([organizationId])
    @@map("application_setup")
}

model ApplicationSetupEvent {
    id        String           @id @default(cuid())
    type      String
    data      Json             @default("{}")
    setupId   String           @map("setup_id")
    setup     ApplicationSetup @relation(fields: [setupId], references: [id], onDelete: Cascade)
    createdAt DateTime         @default(now()) @map("created_at")

    @@index([setupId])
    @@map("application_setup_event")
}

model Member {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           String
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  inviterId      String   @map("inviter_id")
  organizationId String   @map("organization_id")
  role           String
  status         String   @default("pending")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  inviter      User         @relation("invitations", fields: [inviterId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

// --- Application Models ─────────────────────────────────────────────

enum ApplicationArchitecture {
  WEB
  IOS
  ANDROID

  @@map("application_architecture")
}

enum ApplicationMode {
  TRUNK_BASED
  MAIN_ONLY
  MANUAL

  @@map("application_mode")
}

model Application {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @map("slug")
  architecture       ApplicationArchitecture
  mode               ApplicationMode         @default(MAIN_ONLY)
  customInstructions String?                 @map("custom_instructions")

  mainBranchId String? @unique @map("main_branch_id")
  mainBranch   Branch? @relation("MainBranch", fields: [mainBranchId], references: [id])

  webhookUrl       String? @map("webhook_url")
  signingSecretEnc String? @map("signing_secret_enc")

  folders            Folder[]
  testCases          TestCase[]
  skills             Skill[]
  tags               Tag[]
  scenarios          Scenario[]
  scenarioInstances  ScenarioInstance[]
  webhookCalls       WebhookCall[]
  branches           Branch[]
  githubRepositories GitHubRepository[]
    onboardingState    OnboardingState?
    applicationSetups  ApplicationSetup[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, organizationId])
  @@unique([slug, organizationId])
  @@map("application")
}

// ─── Branch Deployment ────────────────────────────────────────────────────────

model BranchDeployment {
  id     String  @id @default(cuid())
  active Boolean @default(true)

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  activeOnBranch   Branch?           @relation("ActiveDeployment")
  snapshots        BranchSnapshot[]  @relation("SnapshotDeployment")
  webDeployment    WebDeployment?
  mobileDeployment MobileDeployment?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("branch_deployment")
}

model WebDeployment {
  deploymentId String           @map("deployment_id")
  deployment   BranchDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  url  String
  file String

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([deploymentId])
  @@map("web_deployment")
}

model MobileDeployment {
  deploymentId String           @map("deployment_id")
  deployment   BranchDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  packageUrl  String @map("package_url")
  photo       String @map("photo")
  packageName String @map("package_name")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([deploymentId])
  @@map("mobile_deployment")
}

// ─── API Key Plugin Model ───────────────────────────────────────────

model ApiKey {
  id                  String    @id @default(cuid())
  name                String?
  start               String?
  prefix              String?
  key                 String
  userId              String    @map("user_id")
  refillInterval      Int?      @map("refill_interval")
  refillAmount        Int?      @map("refill_amount")
  lastRefillAt        DateTime? @map("last_refill_at")
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(false) @map("rate_limit_enabled")
  rateLimitTimeWindow Int?      @map("rate_limit_time_window")
  rateLimitMax        Int?      @map("rate_limit_max")
  requestCount        Int       @default(0) @map("request_count")
  remaining           Int?
  lastRequest         DateTime? @map("last_request")
  expiresAt           DateTime? @map("expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  permissions         String?
  metadata            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_key")
}

// ─── Enums ─────────────────────────────────────────────────────────

enum OrganizationStatus {
  pending
  approved
  rejected

  @@map("organization_status")
}

enum ConversationMessageRole {
  user
  assistant
  system
  tool_call

  @@map("conversation_message_role")
}

// ─── Organization & Test Structure ─────────────────────────────────

model Folder {
  id            String      @id @default(cuid())
  name          String
  description   String?
  applicationId String      @map("application_id")
  parentId      String?     @map("parent_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parent        Folder?     @relation("FolderTree", fields: [parentId], references: [id])
  children      Folder[]    @relation("FolderTree")
  testCases     TestCase[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("folder")
}

// ─── Branch & Versioning ──────────────────────────────────────────────────────

model Branch {
  id   String @id @default(cuid())
  name String

  githubRef String? @map("github_ref")

  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  deploymentId String?           @unique @map("deployment_id")
  deployment   BranchDeployment? @relation("ActiveDeployment", fields: [deploymentId], references: [id])

  activeSnapshotId  String?         @unique @map("active_snapshot_id")
  activeSnapshot    BranchSnapshot? @relation("ActiveSnapshot", fields: [activeSnapshotId], references: [id])
  pendingSnapshotId String?         @unique @map("pending_snapshot_id")
  pendingSnapshot   BranchSnapshot? @relation("PendingSnapshot", fields: [pendingSnapshotId], references: [id])

  mainOfApplication Application?       @relation("MainBranch")
  snapshots         BranchSnapshot[]
  deployments       BranchDeployment[]
  bugs              Bug[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, name])
  @@map("branch")
}

enum TriggerSource {
  GITHUB_PUSH
  MANUAL
  WEBHOOK

  @@map("trigger_source")
}

enum SnapshotStatus {
  processing
  active
  superseded
  failed

  @@map("snapshot_status")
}

model BranchSnapshot {
  id        String         @id @default(cuid())
  status    SnapshotStatus @default(processing)
  createdAt DateTime       @default(now()) @map("created_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  source  TriggerSource
  headSha String?       @map("head_sha")
  baseSha String?       @map("base_sha")
  /// [JsonValue]
  payload Json?

  deploymentId String?           @map("deployment_id")
  deployment   BranchDeployment? @relation("SnapshotDeployment", fields: [deploymentId], references: [id])

  prevSnapshotId String?          @map("prev_snapshot_id")
  prevSnapshot   BranchSnapshot?  @relation("SnapshotHistory", fields: [prevSnapshotId], references: [id])
  nextSnapshots  BranchSnapshot[] @relation("SnapshotHistory")

  testCaseAssignments TestCaseAssignment[]
  skillAssignments    SkillAssignment[]

  activeOnBranch  Branch?          @relation("ActiveSnapshot")
  pendingOnBranch Branch?          @relation("PendingSnapshot")
  testGenerations TestGeneration[]

  @@index([branchId])
  @@map("branch_snapshot")
}

model TestCaseAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  snapshotId String         @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  testCaseId String   @map("test_case_id")
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  planId  String?        @map("plan_id")
  plan    TestPlan?      @relation(fields: [planId], references: [id])
  stepsId String?        @map("steps_id")
  steps   StepInputList? @relation(fields: [stepsId], references: [id])

  mainAssignmentId   String?              @map("main_assignment_id")
  mainAssignment     TestCaseAssignment?  @relation("MainAssignmentRef", fields: [mainAssignmentId], references: [id])
  derivedAssignments TestCaseAssignment[] @relation("MainAssignmentRef")

  runs Run[]

  @@unique([snapshotId, testCaseId])
  @@map("test_case_assignment")
}

model SkillAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  snapshotId String         @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  skillId String @map("skill_id")
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  planId String?    @map("plan_id")
  plan   SkillPlan? @relation(fields: [planId], references: [id])

  mainAssignmentId   String?           @map("main_assignment_id")
  mainAssignment     SkillAssignment?  @relation("MainSkillAssignmentRef", fields: [mainAssignmentId], references: [id])
  derivedAssignments SkillAssignment[] @relation("MainSkillAssignmentRef")

  @@unique([snapshotId, skillId])
  @@map("skill_assignment")
}

// ─── Test Case ────────────────────────────────────────────────────────────────

model TestCase {
  id          String  @id @default(cuid())
  name        String
  slug        String
  description String?

  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  folderId String? @map("folder_id")
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  plans       TestPlan[]
  tags        TestTag[]
  assignments TestCaseAssignment[]
  bugs        Bug[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, slug])
  @@map("test_case")
}

// ─── Skill ───────────────────────────────────────────────────────────────────

model Skill {
  id          String @id @default(cuid())
  name        String
  slug        String
  description String

  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  plans       SkillPlan[]
  assignments SkillAssignment[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, slug])
  @@map("skill")
}

model SkillPlan {
  id      String @id @default(cuid())
  content String

  skillId String @map("skill_id")
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  assignments SkillAssignment[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@map("skill_plan")
}

// ─── Test Generation ───────────────────────────────────────────────────────────

model TestPlan {
  id String @id @default(cuid())

  testCaseId String   @map("test_case_id")
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  prompt     String
  scenarioId String?   @map("scenario_id")
  scenario   Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  generations TestGeneration[]
  stepLists   StepInputList[]
  assignments TestCaseAssignment[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([testCaseId])
  @@map("test_plan")
}

enum GenerationStatus {
  pending
  queued
  running
  success
  failed

  @@map("generation_status")
}

model TestGeneration {
  id         String @id @default(cuid())
  testPlanId String @map("test_plan_id")

  status          GenerationStatus @default(pending)
  reasoning       String?          @map("reasoning")
  finalScreenshot String?          @map("final_screenshot")
  videoUrl        String?          @map("video_url")

  snapshotId String         @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)

  /// [ModelConversation]
  conversation Json @default("[]")

  /// S3 URL where the full conversation JSON is stored
  conversationUrl String? @map("conversation_url")

  /// Extracted variables from the agent's memory system
  memory Json @default("{}") @map("memory")

  testPlan    TestPlan          @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  costRecords AiCostRecord[]
  generationReview GenerationReview?

  scenarioInstanceId String?           @map("scenario_instance_id")
  scenarioInstance   ScenarioInstance? @relation(fields: [scenarioInstanceId], references: [id], onDelete: SetNull)

  stepsId   String?         @map("steps_id")
  steps     StepInputList?  @relation(fields: [stepsId], references: [id])
  outputsId String?         @unique @map("outputs_id")
  outputs   StepOutputList? @relation(fields: [outputsId], references: [id])

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@map("test_generation")
}

// ─── Generation Review ───────────────────────────────────────────────────────

enum GenerationReviewVerdict {
  agent_error
  application_bug

  @@map("generation_review_verdict")
}

enum GenerationReviewStatus {
  pending
  completed
  failed

  @@map("generation_review_status")
}

model GenerationReview {
  id           String         @id @default(cuid())
  generationId String         @unique @map("generation_id")
  generation   TestGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  status    GenerationReviewStatus   @default(pending)
  verdict   GenerationReviewVerdict?
  reasoning String?                  @db.Text
  analysis  Json                     @default("{}")
  issue     Issue?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("generation_review")
}

model RunReview {
  id    String @id @default(cuid())
  runId String @unique @map("run_id")
  run   Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  status    GenerationReviewStatus   @default(pending)
  verdict   GenerationReviewVerdict?
  reasoning String?                  @db.Text
  analysis  Json                     @default("{}")
  issue     Issue?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("run_review")
}

// ─── Issue ───────────────────────────────────────────────────────────────────

enum IssueSeverity {
  critical
  high
  medium
  low

  @@map("issue_severity")
}

enum IssueCategory {
  application_bug
  agent_error

  @@map("issue_category")
}

model Issue {
  id          String            @id @default(cuid())
  generationReviewId String?           @unique @map("review_id")
  generationReview   GenerationReview? @relation(fields: [generationReviewId], references: [id], onDelete: Cascade)
  runReviewId String?           @unique @map("run_review_id")
  runReview   RunReview?        @relation(fields: [runReviewId], references: [id], onDelete: Cascade)

  category    IssueCategory
  confidence  Int
  severity    IssueSeverity
  title       String
  description String        @db.Text
  dismissed   Boolean       @default(false)

  bugId String? @map("bug_id")
  bug   Bug?    @relation(fields: [bugId], references: [id], onDelete: SetNull)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("issue")
}

// ─── Bug ─────────────────────────────────────────────────────────────────────

enum BugStatus {
  open
  resolved
  regressed

  @@map("bug_status")
}

model Bug {
  id          String        @id @default(cuid())
  status      BugStatus     @default(open)
  title       String
  description String        @db.Text
  severity    IssueSeverity

  branchId   String @map("branch_id")
  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  testCaseId String   @map("test_case_id")
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  resolvedAt  DateTime? @map("resolved_at")

  issues Issue[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([branchId, testCaseId])
  @@index([status])
  @@map("bug")
}

// ─── Step Input / Output ──────────────────────────────────────────────────────

model StepInputList {
  id   String      @id @default(cuid())
  list StepInput[]

  planId String   @map("plan_id")
  plan   TestPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  generations TestGeneration[]
  assignments TestCaseAssignment[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("step_input_list")
}

model StepInput {
  id     String @id @default(cuid())
  listId String @map("list_id")
  order  Int

  interaction   String
  /// ![object]
  params        Json
  waitCondition String? @map("wait_condition")

  screenshotBefore String? @map("screenshot_before")
  screenshotAfter  String? @map("screenshot_after")

  list    StepInputList @relation(fields: [listId], references: [id], onDelete: Cascade)
  outputs StepOutput[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([listId, order])
  @@index([listId])
  @@map("step_input")
}

model StepOutputList {
  id   String       @id @default(cuid())
  list StepOutput[]

  generation TestGeneration?

  runId String? @unique @map("run_id")
  run   Run?    @relation(fields: [runId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("step_output_list")
}

model StepOutput {
  id     String @id @default(cuid())
  listId String @map("list_id")
  order  Int

  /// ![object]
  output Json

  stepInputId String    @map("step_input_id")
  stepInput   StepInput @relation(fields: [stepInputId], references: [id])

  screenshotBefore String? @map("screenshot_before")
  screenshotAfter  String? @map("screenshot_after")

  list StepOutputList @relation(fields: [listId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([listId, order])
  @@index([listId])
  @@map("step_output")
}

// ─── Tag ──────────────────────────────────────────────────────────────────────

model Tag {
  id            String @id @default(cuid())
  name          String
  color         String
  applicationId String @map("application_id")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  testTags    TestTag[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tag")
}

model TestTag {
  id         String @id @default(cuid())
  testCaseId String @map("test_case_id")
  tagId      String @map("tag_id")

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, tagId])
  @@map("test_tag")
}

// ─── AI Cost Tracking ─────────────────────────────────────────────

model AiCostRecord {
  id               String   @id @default(cuid())
  generationId     String?  @map("generation_id")
  runId            String?  @map("run_id")
  model            String
  tag              String
  inputTokens      Int      @map("input_tokens")
  outputTokens     Int      @map("output_tokens")
  reasoningTokens  Int      @default(0) @map("reasoning_tokens")
  cacheReadTokens  Int      @default(0) @map("cache_read_tokens")
  costMicrodollars Int      @map("cost_microdollars")
  createdAt        DateTime @default(now()) @map("created_at")

  generation TestGeneration? @relation(fields: [generationId], references: [id], onDelete: Cascade)
  run        Run?            @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([runId])
  @@map("ai_cost_record")
}

// ─── Run Execution ─────────────────────────────────────────────────

enum RunStatus {
  pending
  running
  success
  failed

  @@map("run_status")
}

model Run {
  id          String    @id @default(cuid())
  status      RunStatus @default(pending)
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  assignmentId String             @map("assignment_id")
  assignment   TestCaseAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  scenarioInstanceId String?           @map("scenario_instance_id")
  scenarioInstance   ScenarioInstance? @relation(fields: [scenarioInstanceId], references: [id], onDelete: SetNull)

  outputs     StepOutputList?
  runReview   RunReview?
  costRecords AiCostRecord[]

  reasoning String? @db.Text @map("reasoning")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("run")
}

// ─── Scenario Setup/Teardown ──────────────────────────────────────

enum ScenarioInstanceStatus {
  REQUESTED
  UP_SUCCESS
  UP_FAILED
  RUNNING_TESTS
  DOWN_SUCCESS
  DOWN_FAILED

  @@map("scenario_instance_status")
}

enum WebhookAction {
  DISCOVER
  UP
  DOWN

  @@map("webhook_action")
}

model Scenario {
  id                   String    @id @default(cuid())
  applicationId        String    @map("application_id")
  name                 String
  description          String?
  lastSeenFingerprint  String?   @map("last_seen_fingerprint")
  lastDiscoveredAt     DateTime? @map("last_discovered_at")
  fingerprintChangedAt DateTime? @map("fingerprint_changed_at")
  isDisabled           Boolean   @default(false) @map("is_disabled")

  application Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  instances   ScenarioInstance[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  testPlans      TestPlan[]

  @@unique([applicationId, name])
  @@map("scenario")
}

model ScenarioInstance {
  id            String                 @id @default(cuid())
  applicationId String                 @map("application_id")
  scenarioId    String                 @map("scenario_id")
  status        ScenarioInstanceStatus @default(REQUESTED)

  requestedAt DateTime  @default(now()) @map("requested_at")
  upAt        DateTime? @map("up_at")
  downAt      DateTime? @map("down_at")
  completedAt DateTime? @map("completed_at")
  expiresAt   DateTime? @map("expires_at")

  /// [ScenarioAuth]
  auth      Json?
  /// [ScenarioRefs]
  refs      Json?
  refsToken String? @map("refs_token")
  /// [ScenarioMetadata]
  metadata  Json?
  /// [ScenarioLastError]
  lastError Json?   @map("last_error")

  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scenario        Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  webhookCalls    WebhookCall[]
  testGenerations TestGeneration[]
  runs            Run[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  organizationId  String           @map("organization_id")
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("scenario_instance")
}

model WebhookCall {
  id            String        @id @default(cuid())
  applicationId String        @map("application_id")
  instanceId    String?       @map("instance_id")
  action        WebhookAction

  /// [JsonValue]
  requestBody  Json     @map("request_body")
  /// [JsonValue]
  responseBody Json?    @map("response_body")
  statusCode   Int?     @map("status_code")
  durationMs   Int?     @map("duration_ms")
  error        String?
  createdAt    DateTime @default(now()) @map("created_at")

  application Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  instance    ScenarioInstance? @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("webhook_call")
}

// ─── GitHub Integration ────────────────────────────────────────────

enum GitHubInstallationStatus {
  active
  suspended
  deleted

  @@map("github_installation_status")
}

enum GitHubIndexingStatus {
  pending
  running
  completed
  failed

  @@map("github_indexing_status")
}

enum GitHubDeploymentTrigger {
  push
  github_action

  @@map("github_deployment_trigger")
}

enum GitHubDeploymentStatus {
  pending
  fetching_diff
  ready
  failed

  @@map("github_deployment_status")
}

enum GitHubGenerationStatus {
  pending
  running
  completed
  failed

  @@map("github_generation_status")
}

model GitHubInstallation {
  id             String                   @id @default(cuid())
  installationId Int                      @unique @map("installation_id")
  organizationId String                   @unique @map("organization_id")
  accountLogin   String                   @map("account_login")
  accountId      Int                      @map("account_id")
  accountType    String                   @map("account_type")
  status         GitHubInstallationStatus @default(active)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repositories GitHubRepository[]

  @@map("github_installation")
}

model GitHubRepository {
  id                String                  @id @default(cuid())
  installationId    String                  @map("installation_id")
  githubRepoId      Int                     @map("github_repo_id")
  name              String
  fullName          String                  @map("full_name")
  defaultBranch     String                  @map("default_branch")
  private           Boolean
  indexingStatus    GitHubIndexingStatus    @default(pending) @map("indexing_status")
  indexedAt         DateTime?               @map("indexed_at")
  watchBranch       String                  @default("main") @map("watch_branch")
  deploymentTrigger GitHubDeploymentTrigger @default(push) @map("deployment_trigger")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  generationStatus GitHubGenerationStatus? @map("generation_status")
  autonomaUrl      String?                 @map("autonoma_url")
  testsUrl         String?                 @map("tests_url")

  applicationId String?      @map("application_id")
  application   Application? @relation(fields: [applicationId], references: [id])

  installation GitHubInstallation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  files        GitHubRepositoryFile[]
  deployments  GitHubDeployment[]

  @@unique([installationId, githubRepoId])
  @@map("github_repository")
}

model GitHubDeployment {
  id           String                 @id @default(cuid())
  repositoryId String                 @map("repository_id")
  sha          String
  baseSha      String?                @map("base_sha")
  environment  String
  url          String?
  diff         String?
  status       GitHubDeploymentStatus @default(pending)
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  repository GitHubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("github_deployment")
}

model GitHubRepositoryFile {
  id           String   @id @default(cuid())
  repositoryId String   @map("repository_id")
  path         String
  content      String?
  sha          String
  size         Int
  type         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  repository GitHubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, path])
  @@map("github_repository_file")
}

// ─── Billing ─────────────────────────────────────────────────────

enum SubscriptionStatus {
    active
    canceled
    past_due
    unpaid
    trialing
    paused
    incomplete
    incomplete_expired

    @@map("subscription_status")
}

enum CreditTransactionType {
    SUBSCRIPTION_GRANT
    SUBSCRIPTION_RESET
    FREE_START_GRANT
    PROMO_GRANT
    TOPUP_PURCHASE
    TOPUP_REFUND
    GENERATION_CONSUMPTION
    GENERATION_REFUND
    RUN_CONSUMPTION

    @@map("credit_transaction_type")
}

model BillingCustomer {
    id               String  @id @default(cuid())
    organizationId   String  @unique @map("organization_id")
    stripeCustomerId String? @unique @map("stripe_customer_id")

    subscriptionId     String?             @map("subscription_id")
    subscriptionStatus SubscriptionStatus? @map("subscription_status")
    priceId            String?             @map("price_id")
    currentPeriodStart DateTime?           @map("current_period_start")
    currentPeriodEnd   DateTime?           @map("current_period_end")
    cancelAtPeriodEnd  Boolean             @default(false) @map("cancel_at_period_end")
    gracePeriodEndsAt  DateTime?           @map("grace_period_ends_at")

    creditBalance      Int     @default(0) @map("credit_balance")
    subscriptionCreditBalance Int @default(0) @map("subscription_credit_balance")
    autoTopUpEnabled   Boolean @default(false) @map("auto_top_up_enabled")
    autoTopUpThreshold Int     @default(0) @map("auto_top_up_threshold")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    transactions CreditTransaction[]

    @@map("billing_customer")
}

model BillingPricing {
    id             String @id @default(cuid())
    organizationId String @unique @map("organization_id")

    creditsPerSubscription      Int @default(1000000) @map("credits_per_subscription")
    creditsPerTopup             Int @default(150000) @map("credits_per_topup")
    creditsFreeStart            Int @default(100000) @map("credits_free_start")
    creditsWebGenerationCost    Int @default(500) @map("credits_web_generation_cost")
    creditsIosGenerationCost    Int @default(700) @map("credits_ios_generation_cost")
    creditsAndroidGenerationCost Int @default(540) @map("credits_android_generation_cost")
    creditsWebRunCost           Int @default(10) @map("credits_web_run_cost")
    creditsIosRunCost           Int @default(200) @map("credits_ios_run_cost")
    creditsAndroidRunCost       Int @default(40) @map("credits_android_run_cost")
    stripeTopupAmountCents      Int @default(10000) @map("stripe_topup_amount_cents")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    @@map("billing_pricing")
}

model CreditTransaction {
    id             String                @id @default(cuid())
    organizationId String                @map("organization_id")
    type           CreditTransactionType
    amount         Int
    balanceAfter   Int                   @map("balance_after")

    generationId          String? @unique @map("generation_id")
    runId                 String? @unique @map("run_id")
    stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")
    stripeInvoiceId       String? @unique @map("stripe_invoice_id")
    stripeRefundId        String? @unique @map("stripe_refund_id")
    promoRedemptionId     String? @unique @map("promo_redemption_id")

    createdAt DateTime @default(now()) @map("created_at")

    billingCustomer BillingCustomer       @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
    promoRedemption BillingPromoRedemption? @relation(fields: [promoRedemptionId], references: [id], onDelete: SetNull)

    @@index([organizationId])
    @@map("credit_transaction")
}

model BillingPromoCode {
    id String @id @default(cuid())

    code         String  @unique
    description  String?
    grantCredits Int     @map("grant_credits")

    maxRedemptions Int? @map("max_redemptions")
    redeemedCount  Int  @default(0) @map("redeemed_count")

    startsAt DateTime? @map("starts_at")
    endsAt   DateTime? @map("ends_at")
    isActive Boolean   @default(true) @map("is_active")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    redemptions BillingPromoRedemption[]

    @@map("billing_promo_code")
}

model BillingPromoRedemption {
    id String @id @default(cuid())

    promoCodeId    String @map("promo_code_id")
    organizationId String @map("organization_id")

    redeemedAt DateTime @default(now()) @map("redeemed_at")

    promoCode         BillingPromoCode   @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
    organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
    creditTransaction CreditTransaction?

    @@index([promoCodeId])
    @@index([organizationId])
    @@unique([promoCodeId, organizationId])
    @@map("billing_promo_redemption")
}
