{
    "name": "@autonoma/db",
    "version": "0.0.2",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./env": "./src/env.ts"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --passWithNoTests",
        "db": "dotenv -e ../../.env -- prisma",
        "db:generate": "DATABASE_URL=${DATABASE_URL:-postgres://postgres:postgres@localhost:5432/placeholder} pnpm db generate",
        "postinstall": "pnpm db:generate",
        "db:migrate": "pnpm db migrate dev",
        "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts"
    },
    "dependencies": {
        "@autonoma/utils": "workspace:*",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@t3-oss/env-core": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "ai": "catalog:",
        "better-auth": "catalog:",
        "dotenv": "catalog:",
        "dotenv-cli": "^11.0.0",
        "prisma": "^7.5.0",
        "prisma-json-types-generator": "^4.1.1",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
