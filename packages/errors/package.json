{
    "name": "@autonoma/errors",
    "version": "0.0.1",
    "private": true,
    "description": "Error handling utilities for Autonoma",
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
