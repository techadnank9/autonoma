{
    "plugins": ["typescript", "import", "react", "jsx-a11y"],
    "rules": {
        "no-unused-vars": "error",
        "@typescript-eslint/consistent-type-imports": "error",
        "jsx-a11y/click-events-have-key-events": "off"
    },
    "ignorePatterns": [
        "**/dist/**",
        "**/node_modules/**",
        "**/.turbo/**",
        "**/generated/**",
        "**/.prisma/**",
        "**/*.gen.ts"
    ]
}
